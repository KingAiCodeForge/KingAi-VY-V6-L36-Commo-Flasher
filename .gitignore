# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Generated logs — one per session, don't commit
logs/

# Test reports — generated by pytest-html
tests/*.html
last_report.html

# pytest cache
.pytest_cache/

# ignore/ contains private research, real ECU bin files, old backups, PDFs
# Do NOT commit bin files — they contain real ECU firmware
ignore/

# OS junk
Thumbs.db
.DS_Store
desktop.ini

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Local test/debug scripts with machine-specific paths
tests/_batch_export_all_bins.py
tests/_cli_integration_test.py
tests/_diff_exports.py

# Empty archive dirs
older_versions/
